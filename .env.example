# Copy to .env.local for local dev. .env.local is gitignored.
# In production: add these via Vercel Dashboard → Settings → Environment Variables.

# DeepSeek API key — server-only, NEVER prefix with NEXT_PUBLIC_.
# Get one at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# Optional feature flag for the chat widget (default: enabled).
# NEXT_PUBLIC_CHAT_ENABLED=true

# Future: when migrating rate-limit to Upstash Redis / Vercel KV.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
